# Backend environment — copy to `.env` and fill in values.
# NEVER commit `.env`. See docs/SECURITY.md.

# Corridor config (default: India-wide; use mumbai config for demo)
# RAILMIND_CONFIG=config/mumbai_csmt_igatpuri.yaml

# Optional — multi-LLM verification + explanations (graceful fallback without keys)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --------------------------------------------------------------------------- #
# Live running-status feed (NTES-backed). WITHOUT a key the engine still runs:
# it falls back to schedule-driven replay and every train is honestly tagged
# SIM. Add the key below and the trains the feed covers flip to LIVE/INTERPOLATED
# automatically — no code change.
#
# How to get one: sign up at https://rapidapi.com, subscribe (free tier) to an
# "Indian Railways / IRCTC live train status" API (e.g. the IRCTC1 listing),
# then copy the key + host from the listing's code snippet.
# --------------------------------------------------------------------------- #
# Wired/tested against the "Indian Railway IRCTC" RapidAPI listing:
RAILMIND_RAPIDAPI_KEY=
RAILMIND_RAPIDAPI_HOST=indian-railway-irctc.p.rapidapi.com
RAILMIND_RAPIDAPI_PATH=/api/trains/v1/train/status
# RAILMIND_RAPIDAPI_DATE=20260609   # optional: pin the journey date (else IST today)
